# Públicas (frontend)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# URL pública da loja (SEO, sitemap, canonical, JSON-LD, Merchant Center)
# Ex.: https://www.batistacosmeticos.com.br — sem barra no final
NEXT_PUBLIC_SITE_URL=https://www.batistacosmeticos.com.br

# Secretas (apenas servidor — sem NEXT_PUBLIC)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Dev local: contorna falha de envio de e-mail de confirmação (NUNCA use em produção)
# SUPABASE_BYPASS_EMAIL_CONFIRM=true

# SEO Merchant (opcional — dias de devolução / separação)
# Alinhado à política: arrependimento 7 dias; processamento 1–2 dias úteis
SEO_RETURN_DAYS=7
SEO_HANDLING_DAYS_MAX=2

# PayoutBR — pagamento na loja (Pix + cartão tokenizado)
# https://payoutbr.readme.io/reference/introducao
PAYOUT_SECRET_KEY=sk_test_sua-chave-secreta
PAYOUT_PUBLIC_KEY=pk_test_sua-chave-publica
PAYOUT_API_URL=https://api.payoutbr.com.br/v1

# Resend — e-mails transacionais (pedido confirmado etc.)
# Domínio batistacosmeticos.com.br deve estar verificado no Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Batista Cosméticos <atendimento@batistacosmeticos.com.br>
